# Database Configuration
# @required @type url
DATABASE_URL=postgresql://user:password@localhost:5432/corkboard

# Test Database Configuration
# @type url @description "Test database connection string - use separate PostgreSQL database for tests"
TEST_DATABASE_URL=postgresql://user:password@localhost:5432/corkboard_test

# API Server Configuration
# @type number @default 3000
PORT=3000

# Session & Authentication
# @required @type string @description "Secret key for session encryption - generate with: openssl rand -base64 32"
SESSION_SECRET=generate-random-secret-key-here

# @required @type string @description "JWT signing secret - generate with: openssl rand -base64 32"
JWT_SECRET=generate-random-jwt-secret-here

# AWS S3 Configuration (for media storage)
# @type string
AWS_S3_BUCKET=your-bucket-name

# @type string
AWS_REGION=us-east-1

# @type string @description "AWS Access Key ID - use IAM roles in production"
AWS_ACCESS_KEY_ID=your-access-key-id

# @type string @description "AWS Secret Access Key - use IAM roles in production"
AWS_SECRET_ACCESS_KEY=your-secret-access-key

# Mobile App Configuration
# @type url @description "API URL for mobile app to connect to"
EXPO_PUBLIC_API_URL=http://localhost:3000

# Environment
# @type enum @enumValues development,production,test @default development
NODE_ENV=development

# Logging
# @type enum @enumValues debug,info,warn,error @default info
LOG_LEVEL=info

# Server-Sent Events (SSE) Configuration
# @type number @description "Heartbeat interval in seconds to keep SSE connections alive" @default 30
SSE_HEARTBEAT_INTERVAL=30

# @type number @description "Maximum SSE connection duration in minutes before forcing reconnect" @default 15
SSE_MAX_CONNECTION_MINUTES=15

# Spotify Configuration (for music integration)
# @type string @description "Spotify Client ID from Spotify Developer Dashboard"
SPOTIFY_CLIENT_ID=your-spotify-client-id

# @type string @description "Spotify Client Secret from Spotify Developer Dashboard"
SPOTIFY_CLIENT_SECRET=your-spotify-client-secret
